{%- liquid
  assign current_variant = product.selected_or_first_available_variant
  assign product_form_id = 'ProductForm-' | append: section.id
-%}

<section
  class="main-product"
  id="MainProduct-{{ section.id }}"
  data-section="{{ section.id }}"
>
  <div class="container">
    <div class="product-layout">

      {%- comment -%} Gallery column {%- endcomment -%}
      <div class="product-gallery" id="ProductGallery-{{ section.id }}">
        <div class="product-gallery__main" id="ProductGalleryMain">
          {%- if product.featured_media -%}
            {{
              product.featured_media
              | image_url: width: 1200
              | image_tag:
                class: 'product-gallery__main-image',
                id: 'ProductMainImage',
                loading: 'eager',
                fetchpriority: 'high',
                sizes: '(min-width: 1024px) 55vw, 100vw',
                widths: '500, 700, 900, 1100, 1200',
                alt: product.featured_media.alt | default: product.title
            }}
          {%- endif -%}
        </div>

        {%- if product.media.size > 1 -%}
          <div class="product-gallery__thumbnails" role="list" aria-label="{{ 'products.product.media.gallery_viewer' | t | default: 'Product images' }}">
            {%- for media in product.media -%}
              <button
                class="product-gallery__thumb{% if forloop.first %} product-gallery__thumb--active{% endif %}"
                data-media-id="{{ media.id }}"
                data-image-url="{{ media | image_url: width: 1200 }}"
                aria-label="{{ 'products.product.media.load_image' | t: index: forloop.index | default: 'Load image' }} {{ forloop.index }}"
                aria-current="{% if forloop.first %}true{% else %}false{% endif %}"
                role="listitem"
              >
                {{
                  media
                  | image_url: width: 160
                  | image_tag:
                    loading: 'lazy',
                    sizes: '80px',
                    widths: '80, 120, 160',
                    alt: media.alt | default: product.title
                }}
              </button>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>

      {%- comment -%} Product info column {%- endcomment -%}
      <div class="product-info{% if section.settings.enable_sticky_info %} product-info--sticky{% endif %}">

        {%- for block in section.blocks -%}
          {%- case block.type -%}

            {%- when 'vendor' -%}
              {%- if product.vendor != blank -%}
                <p class="product-info__vendor" {{ block.shopify_attributes }}>
                  <a href="{{ product.vendor | url_for_vendor }}" class="product-info__vendor-link">
                    {{ product.vendor }}
                  </a>
                </p>
              {%- endif -%}

            {%- when 'title' -%}
              <h1 class="product-info__title" {{ block.shopify_attributes }}>
                {{ product.title }}
              </h1>

            {%- when 'price' -%}
              <div class="product-info__price" {{ block.shopify_attributes }} id="ProductPrice-{{ section.id }}">
                {%- render 'price', product: product, show_badges: true -%}
              </div>

            {%- when 'variant-picker' -%}
              {%- unless product.has_only_default_variant -%}
                <div class="product-info__variants" {{ block.shopify_attributes }}>
                  {%- for option in product.options_with_values -%}
                    <div class="variant-picker" data-option-name="{{ option.name | downcase }}">
                      <div class="variant-picker__label">
                        <span>{{ option.name }}</span>
                        {%- if option.name == 'Size' -%}
                          <button class="variant-picker__size-guide" type="button">Size Guide</button>
                        {%- endif -%}
                      </div>

                      {%- if block.settings.picker_type == 'button' -%}
                        <div class="variant-picker__buttons" role="group" aria-label="{{ option.name }}">
                          {%- for value in option.values -%}
                            {%- liquid
                              assign available = false
                              for variant in product.variants
                                if variant.option1 == value or variant.option2 == value or variant.option3 == value
                                  if variant.available
                                    assign available = true
                                  endif
                                endif
                              endfor
                            -%}
                            <label class="variant-picker__swatch{% unless available %} variant-picker__swatch--unavailable{% endunless %}">
                              <input
                                type="radio"
                                name="option-{{ option.position }}"
                                value="{{ value | escape }}"
                                class="visually-hidden"
                                {% if option.selected_value == value %}checked{% endif %}
                                {% unless available %}disabled{% endunless %}
                                data-option-position="{{ option.position }}"
                              >
                              <span class="variant-picker__swatch-label">{{ value }}</span>
                            </label>
                          {%- endfor -%}
                        </div>
                      {%- else -%}
                        <select
                          name="option-{{ option.position }}"
                          class="form-select variant-picker__select"
                          data-option-position="{{ option.position }}"
                          aria-label="{{ option.name }}"
                        >
                          {%- for value in option.values -%}
                            <option
                              value="{{ value | escape }}"
                              {% if option.selected_value == value %}selected{% endif %}
                            >{{ value }}</option>
                          {%- endfor -%}
                        </select>
                      {%- endif -%}
                    </div>
                  {%- endfor -%}
                </div>
              {%- endunless -%}

            {%- when 'quantity-selector' -%}
              <div class="product-info__quantity" {{ block.shopify_attributes }}>
                <label class="product-info__quantity-label" for="Quantity-{{ section.id }}">
                  {{ 'products.product.quantity.label' | t | default: 'Quantity' }}
                </label>
                <div class="quantity-input">
                  <button
                    class="quantity-input__btn quantity-input__btn--minus"
                    type="button"
                    aria-label="{{ 'products.product.quantity.decrease' | t | default: 'Decrease quantity' }}"
                    data-action="decrease"
                  >
                    {%- render 'icon', icon: 'minus' -%}
                  </button>
                  <input
                    type="number"
                    id="Quantity-{{ section.id }}"
                    name="quantity"
                    value="1"
                    min="1"
                    class="quantity-input__field"
                    aria-label="{{ 'products.product.quantity.input_label' | t: product: product.title | default: 'Quantity' }}"
                  >
                  <button
                    class="quantity-input__btn quantity-input__btn--plus"
                    type="button"
                    aria-label="{{ 'products.product.quantity.increase' | t | default: 'Increase quantity' }}"
                    data-action="increase"
                  >
                    {%- render 'icon', icon: 'plus' -%}
                  </button>
                </div>
              </div>

            {%- when 'buy-buttons' -%}
              <div class="product-info__buy-buttons" {{ block.shopify_attributes }}>
                {%- form 'product', product, id: product_form_id, class: 'product-form', novalidate: 'novalidate', data-product-form: '' -%}
                  <input type="hidden" name="id" value="{{ current_variant.id }}" id="ProductVariantId-{{ section.id }}">
                  <input type="hidden" name="quantity" id="ProductQuantity-{{ section.id }}" value="1">

                  <button
                    type="submit"
                    name="add"
                    class="btn btn--primary product-form__submit"
                    id="ProductSubmitBtn-{{ section.id }}"
                    {%- unless current_variant.available %}disabled aria-disabled="true"{% endunless -%}
                    aria-label="{% if current_variant.available %}{{ 'products.product.add_to_cart' | t | default: 'Add to cart' }}{% else %}{{ 'products.product.sold_out' | t | default: 'Sold out' }}{% endif %}"
                  >
                    <span id="ProductSubmitBtnText">
                      {%- if current_variant.available -%}
                        {{ 'products.product.add_to_cart' | t | default: 'Add to cart' }}
                      {%- else -%}
                        {{ 'products.product.sold_out' | t | default: 'Sold out' }}
                      {%- endif -%}
                    </span>
                    <span class="product-form__submit-spinner" aria-hidden="true"></span>
                  </button>

                  {%- if block.settings.show_dynamic_checkout -%}
                    {{ form | payment_button }}
                  {%- endif -%}
                {%- endform -%}
              </div>

            {%- when 'description' -%}
              {%- if product.description != blank -%}
                <div class="product-info__description accordion" {{ block.shopify_attributes }}>
                  <button
                    class="accordion__trigger"
                    type="button"
                    aria-expanded="true"
                    aria-controls="ProductDescription-{{ section.id }}"
                  >
                    <span>{{ 'products.product.description' | t | default: 'Description' }}</span>
                    {%- render 'icon', icon: 'plus' -%}
                  </button>
                  <div
                    class="accordion__content rte"
                    id="ProductDescription-{{ section.id }}"
                  >
                    {{ product.description }}
                  </div>
                </div>
              {%- endif -%}

            {%- when 'collapsible-tab' -%}
              {%- if block.settings.heading != blank -%}
                <div class="product-info__tab accordion" {{ block.shopify_attributes }}>
                  <button
                    class="accordion__trigger"
                    type="button"
                    aria-expanded="false"
                    aria-controls="Tab-{{ block.id }}"
                  >
                    <span>{{ block.settings.heading }}</span>
                    {%- render 'icon', icon: 'plus' -%}
                  </button>
                  <div class="accordion__content rte" id="Tab-{{ block.id }}">
                    {{ block.settings.content }}
                  </div>
                </div>
              {%- endif -%}

          {%- endcase -%}
        {%- endfor -%}

      </div>
    </div>
  </div>

  {%- comment -%} Product variants JSON for JS {%- endcomment -%}
  <script type="application/json" id="ProductVariantsJson-{{ section.id }}">
    {{ product.variants | json }}
  </script>
</section>

{% schema %}
{
  "name": "Product — Main",
  "tag": "section",
  "class": "section-main-product",
  "blocks": [
    {
      "type": "vendor",
      "name": "Vendor",
      "limit": 1,
      "settings": []
    },
    {
      "type": "title",
      "name": "Title",
      "limit": 1,
      "settings": []
    },
    {
      "type": "price",
      "name": "Price",
      "limit": 1,
      "settings": []
    },
    {
      "type": "variant-picker",
      "name": "Variant picker",
      "limit": 1,
      "settings": [
        {
          "type": "select",
          "id": "picker_type",
          "label": "Picker type",
          "default": "button",
          "options": [
            { "value": "button", "label": "Button / swatch" },
            { "value": "dropdown", "label": "Dropdown" }
          ]
        }
      ]
    },
    {
      "type": "quantity-selector",
      "name": "Quantity selector",
      "limit": 1,
      "settings": []
    },
    {
      "type": "buy-buttons",
      "name": "Buy buttons",
      "limit": 1,
      "settings": [
        {
          "type": "checkbox",
          "id": "show_dynamic_checkout",
          "default": true,
          "label": "Show dynamic checkout buttons",
          "info": "Shows payment buttons like Shop Pay, Apple Pay. Requires the cart page."
        }
      ]
    },
    {
      "type": "description",
      "name": "Description",
      "limit": 1,
      "settings": []
    },
    {
      "type": "collapsible-tab",
      "name": "Collapsible tab",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Tab heading",
          "default": "Shipping & Returns"
        },
        {
          "type": "richtext",
          "id": "content",
          "label": "Tab content"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "checkbox",
      "id": "enable_sticky_info",
      "default": true,
      "label": "Enable sticky product info on desktop"
    }
  ],
  "presets": [
    {
      "name": "Product — Main",
      "blocks": [
        { "type": "vendor" },
        { "type": "title" },
        { "type": "price" },
        { "type": "variant-picker" },
        { "type": "quantity-selector" },
        { "type": "buy-buttons" },
        { "type": "description" }
      ]
    }
  ]
}
{% endschema %}
